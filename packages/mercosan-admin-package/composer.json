{
    "name": "functionbytes/mercosan-admin-package",
    "description": "Paquete completo de administración con páginas, settings, ACL, audit log y tema para Mercosan",
    "type": "library",
    "keywords": ["laravel", "admin", "settings", "acl", "audit-log", "mercosan"],
    "license": "MIT",
    "authors": [
        {
            "name": "FunctionBytes",
            "email": "info@functionbytes.com"
        }
    ],
    "require": {
        "php": "^8.1|^8.2|^8.3",
        "illuminate/support": "^10.0|^11.0",
        "illuminate/database": "^10.0|^11.0",
        "illuminate/http": "^10.0|^11.0"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0|^9.0",
        "phpunit/phpunit": "^10.0|^11.0"
    },
    "autoload": {
        "psr-4": {
            "FunctionBytes\\MercosanAdmin\\": "src/"
        },
        "files": [
            "src/Helpers/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "FunctionBytes\\MercosanAdmin\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "FunctionBytes\\MercosanAdmin\\MercosanAdminServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
