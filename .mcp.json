{
    "mcpServers": {
        "laravel-boost": {
            "command": "php",
            "args": [
                "artisan",
                "boost:mcp"
            ]
        },
        "chrome-devtools": {
            "command": "npx",
            "args": [
                "--yes",
                "chrome-devtools-mcp@latest",
                "--browserUrl",
                "http://127.0.0.1:9222"
            ]
        },
        "redis": {
            "command": "npx",
            "args": [
                "--yes",
                "@anthropic/mcp-redis"
            ],
            "env": {
                "REDIS_URL": "redis://localhost:6379"
            }
        }
    }
}
